generator client {
  provider = "prisma-client-js"
  // 生成物を core パッケージ内に出力 → pnpm deploy で確実に同梱される（モノレポ対策）
  output   = "../src/generated/prisma"
  // native = ローカル(darwin-arm64等) / linux-arm64-openssl-3.0.x = Oracle ARM64 Docker(node:22-slim)
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Discord ユーザー ↔ いかすきー(Misskey)ユーザー の紐付け
model Link {
  discordId     String    @id
  guildId       String
  misskeyId     String    @unique
  username      String
  misskeyHost   String?
  /// MiAuth トークン（M3でトークン失効検知に使用。任意保存）
  token         String?
  /// active / pending_kick / kicked
  status        String    @default("active")
  /// 連続検証失敗カウント（誤検知対策の安全弁。M3で使用）
  failureCount  Int       @default(0)
  linkedAt      DateTime  @default(now())
  lastCheckedAt DateTime?

  @@index([status])
}

/// 認証フローの一時状態。ボタン押下(bot)とMiAuthコールバック(web)を結ぶ
model VerificationState {
  /// 推測不能なnonce（URLに載るのはこれだけ）
  nonce          String    @id
  discordId      String
  guildId        String
  /// /start で採番する MiAuth セッションUUID
  misskeySession String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?

  @@index([expiresAt])
}

/// Misskeyロール → Discordロール の連動設定（管理画面で編集。M4で使用）
model RoleMapping {
  misskeyRoleId   String  @id
  misskeyRoleName String
  discordRoleId   String
  enabled         Boolean @default(true)
  autoSync        Boolean @default(true)
}

/// 検証除外リスト（モデレーター等。M3で使用）
model Allowlist {
  discordId String   @id
  reason    String
  createdAt DateTime @default(now())
}

/// 管理画面のログインセッション（MiAuth認証・モデレーター/管理者ゲート。M5）
model AdminSession {
  /// Cookie に載るセッションID（推測不能）
  id          String   @id
  misskeyId   String
  username    String
  /// roles/list 等の呼び出しに使う MiAuth トークン
  token       String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

/// 監査ログ（認証・キック・ロール同期・設定変更の記録。M5で閲覧）
model AuditLog {
  id              Int      @id @default(autoincrement())
  at              DateTime @default(now())
  /// auth / kick / role_sync / mapping_change / allowlist_change など
  type            String
  /// 操作者（管理画面操作なら管理者の misskeyId、システムなら null）
  actor           String?
  /// 対象の Discord ユーザーID（該当する場合）
  targetDiscordId String?
  /// 人間可読の要約
  summary         String

  @@index([at])
  @@index([type])
}
