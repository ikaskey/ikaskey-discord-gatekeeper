# ===== Discord =====
# Bot Token（Developer Portal → Bot）
DISCORD_TOKEN=
# Application(Client) ID
DISCORD_CLIENT_ID=
# 対象サーバー(Guild) ID
DISCORD_GUILD_ID=
# 「認証済み」ロールの ID（認証成功で付与）
VERIFIED_ROLE_ID=
# OAuth2 Client Secret（任意・未参加ユーザーの自動参加フロー /join を使う場合のみ）
# Developer Portal → OAuth2。Redirect URI に <PUBLIC_BASE_URL>/join/discord/callback を登録
DISCORD_CLIENT_SECRET=
# 認証完了後に誘導するDiscordサーバーURL（任意・既定はGuildディープリンク）
DISCORD_SERVER_URL=

# ===== Misskey =====
# 対象 Misskey インスタンスのホスト名
MISSKEY_HOST=misskey.example.com
# 認可画面に表示されるアプリ名
MISSKEY_APP_NAME=会員認証
# Misskeyのモデレーター/管理者に連動して付与するDiscordロールID（任意・M7）
MISSKEY_MODERATOR_ROLE_ID=
MISSKEY_ADMIN_ROLE_ID=

# ===== Web（MiAuthコールバック / 管理API）=====
# 外部公開URL（リバースプロキシ/トンネルのホスト名）。MiAuthのcallbackに使う
PUBLIC_BASE_URL=https://gatekeeper.example.com
WEB_PORT=3001

# ===== 定期検証スイープ（退会連動の即キック・M3）=====
# キルスイッチ。移行期間中は false にしてキックを完全停止できる（既定: true）
SWEEP_ENABLED=true
# 実行スケジュール（cron式）。既定は6時間ごと
SWEEP_CRON=0 0,6,12,18 * * *
# 連続「消滅」確認がこの回数でキック（1=即キック、2以上で慎重に）
SWEEP_FAILURE_THRESHOLD=1
# 同一スイープ内で消滅を再確認するまでの待ち時間(ms)
SWEEP_RECHECK_DELAY_MS=3000

# ===== 管理画面（M5）=====
# セッションCookieの署名鍵（十分に長いランダム文字列）。未設定だと /admin は無効
# 生成例: openssl rand -base64 48
ADMIN_COOKIE_SECRET=

# ===== 段階移行 Phase 3（未認証キック）=====
# /migration-purge で実キックを許可するか（既定 false=dry-runのみ）。
# Phase 3 に到達し、実際に未認証をキックする段になったら true にする
MIGRATION_PURGE_ENABLED=false

# ===== DB（PostgreSQL）=====
# Prisma provider は postgresql。ローカルは docker compose の postgres サービスを使う。
DATABASE_URL=postgresql://gatekeeper:gatekeeper@localhost:5432/gatekeeper?schema=public
# docker compose 内からは host=postgres:
# DATABASE_URL=postgresql://gatekeeper:gatekeeper@postgres:5432/gatekeeper?schema=public
# postgres サービス用の認証情報（compose が参照）
POSTGRES_USER=gatekeeper
POSTGRES_PASSWORD=gatekeeper
POSTGRES_DB=gatekeeper

# ===== ブランディング（任意・差し替え可能）=====
# 管理画面/参加ページ/認証結果ページに使うファビコン・OGP画像など。空なら未設定。
BRAND_FAVICON_URL=
BRAND_OG_IMAGE_URL=
BRAND_OG_TITLE=
BRAND_OG_DESCRIPTION=
BRAND_THEME_COLOR=#86b300
