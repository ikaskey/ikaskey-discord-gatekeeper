# ===== Discord =====
# Bot Token（Developer Portal → Bot）
DISCORD_TOKEN=
# Application(Client) ID
DISCORD_CLIENT_ID=
# 対象サーバー(Guild) ID
DISCORD_GUILD_ID=
# 「いかすきー認証済み」ロールの ID（認証成功で付与）
VERIFIED_ROLE_ID=

# ===== Misskey（いかすきー）=====
MISSKEY_HOST=ikaskey.bktsk.com
# 認可画面に表示されるアプリ名
MISSKEY_APP_NAME=いかすきー会員認証

# ===== Web（MiAuthコールバック / 管理API）=====
# 外部公開URL（cloudflaredトンネルのホスト名）。MiAuthのcallbackに使う
PUBLIC_BASE_URL=https://ikaskey-gate.bktsk.com
WEB_PORT=3001

# ===== 定期検証スイープ（退会連動の即キック・M3）=====
# 実行スケジュール（cron式）。既定は6時間ごと
SWEEP_CRON=0 0,6,12,18 * * *
# 連続「消滅」確認がこの回数でキック（1=即キック、2以上で慎重に）
SWEEP_FAILURE_THRESHOLD=1
# 同一スイープ内で消滅を再確認するまでの待ち時間(ms)
SWEEP_RECHECK_DELAY_MS=3000

# ===== 管理画面（M5）=====
# セッションCookieの署名鍵（十分に長いランダム文字列）。未設定だと /admin は無効
# 生成例: openssl rand -base64 48
ADMIN_COOKIE_SECRET=

# ===== DB =====
# パスは schema.prisma（packages/core/prisma/）からの相対。
# ローカル開発: packages/core/prisma/dev.db に作られる
DATABASE_URL=file:./dev.db
# 本番(Docker)では絶対パスのバインドマウントを使う:
# DATABASE_URL=file:/data/prod.db
