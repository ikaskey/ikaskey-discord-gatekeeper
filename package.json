{
  "name": "ikaskey-discord-gatekeeper",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @gatekeeper/web dev",
    "dev:bot": "pnpm --filter @gatekeeper/bot dev",
    "bot:deploy-commands": "pnpm --filter @gatekeeper/bot deploy-commands",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "prisma:generate": "pnpm --filter @gatekeeper/core prisma:generate",
    "prisma:migrate": "pnpm --filter @gatekeeper/core prisma:migrate",
    "prisma:deploy": "pnpm --filter @gatekeeper/core prisma:deploy"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
